@model Sockethead.Razor.Pager.PagerModel
<nav aria-label="Pager" class="sh-pager SimpleGridPagination">
    <div class="sh-pager-info">
        @if (Model.TotalItems.HasValue)
        {
            <span class="sh-pager-total">@Model.TotalItems.Value.ToString("N0") records</span>
        }
        @if (!Model.HideNavigation)
        {
            <span class="sh-pager-pages">Page @Model.CurrentPage of @Model.TotalPages</span>
        }
    </div>
    <div class="sh-pager-controls">
        @if (Model.RowsPerPageLinks != null)
        {
            <div class="sh-pager-rpp">
                <span class="sh-pager-rpp-label">Rows:</span>
                @foreach (var kvp in Model.RowsPerPageLinks)
                {
                    <a class="sh-pager-rpp-link" href="@kvp.Value">@kvp.Key.ToString("N0")</a>
                }
            </div>
        }
        @if (!Model.HideNavigation)
        {
        <div class="sh-pager-buttons">
            @{ PagerBtn(Model.FirstUrl, "&#171;", "First page"); }
            @{ PagerBtn(Model.PrevUrl, "&#8249;", "Previous page"); }
            @{ PagerBtn(Model.NextUrl, "&#8250;", "Next page"); }
            @{ PagerBtn(Model.LastUrl, "&#187;", "Last page"); }
        </div>
        }
    </div>
</nav>

@functions {
    void PagerBtn(string url, string symbol, string ariaLabel)
    {
        if (string.IsNullOrEmpty(url))
        {
            WriteLiteral($"<span class=\"sh-pager-btn disabled\" aria-disabled=\"true\" aria-label=\"{ariaLabel}\" title=\"{ariaLabel}\">{symbol}</span>\n");
        }
        else
        {
            WriteLiteral($"<a class=\"sh-pager-btn\" href=\"{url}\" aria-label=\"{ariaLabel}\" title=\"{ariaLabel}\">{symbol}</a>\n");
        }
    }
}
