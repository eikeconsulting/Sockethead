@model Sockethead.Razor.Pager.PagerModel
@{
    string IsDisabled(string s) => string.IsNullOrEmpty(s) ? "disabled" : "";
    string AriaDisabled(string s) => string.IsNullOrEmpty(s) ? "true" : "false";
}
<nav aria-label="Pager" class="sh-pager SimpleGridPagination">
    <div class="sh-pager-info">
        @if (Model.TotalItems.HasValue)
        {
            <span class="sh-pager-total">@Model.TotalItems.Value.ToString("N0") records</span>
        }
        <span class="sh-pager-pages">Page @Model.CurrentPage of @Model.TotalPages</span>
    </div>
    <div class="sh-pager-controls">
        @if (Model.RowsPerPageLinks != null)
        {
            <div class="sh-pager-rpp">
                <span class="sh-pager-rpp-label">Rows:</span>
                @foreach (var kvp in Model.RowsPerPageLinks)
                {
                    <a class="sh-pager-rpp-link" href="@kvp.Value">@kvp.Key.ToString("N0")</a>
                }
            </div>
        }
        <div class="sh-pager-buttons">
            <a class="sh-pager-btn @IsDisabled(Model.FirstUrl)" href="@Model.FirstUrl" title="First" aria-label="First page" aria-disabled="@AriaDisabled(Model.FirstUrl)">&#171;</a>
            <a class="sh-pager-btn @IsDisabled(Model.PrevUrl)" href="@Model.PrevUrl" title="Previous" aria-label="Previous page" aria-disabled="@AriaDisabled(Model.PrevUrl)">&#8249;</a>
            <a class="sh-pager-btn @IsDisabled(Model.NextUrl)" href="@Model.NextUrl" title="Next" aria-label="Next page" aria-disabled="@AriaDisabled(Model.NextUrl)">&#8250;</a>
            <a class="sh-pager-btn @IsDisabled(Model.LastUrl)" href="@Model.LastUrl" title="Last" aria-label="Last page" aria-disabled="@AriaDisabled(Model.LastUrl)">&#187;</a>
        </div>
    </div>
</nav>
