@model Sockethead.Razor.Pager.PagerModel
<nav aria-label="Pager" class="sh-pager SimpleGridPagination">
    <div class="sh-pager-info">
        @if (Model.TotalItems.HasValue)
        {
            <span class="sh-pager-total">@Model.TotalItems.Value.ToString("N0") records</span>
        }
        <span class="sh-pager-pages">Page @Model.CurrentPage of @Model.TotalPages</span>
    </div>
    <div class="sh-pager-controls">
        @if (Model.RowsPerPageLinks != null)
        {
            <div class="sh-pager-rpp">
                <span class="sh-pager-rpp-label">Rows:</span>
                @foreach (var kvp in Model.RowsPerPageLinks)
                {
                    <a class="sh-pager-rpp-link" href="@kvp.Value">@kvp.Key.ToString("N0")</a>
                }
            </div>
        }
        <div class="sh-pager-buttons">
            @if (string.IsNullOrEmpty(Model.FirstUrl))
            {
                <span class="sh-pager-btn disabled" aria-disabled="true" aria-label="First page" title="First">&#171;</span>
            }
            else
            {
                <a class="sh-pager-btn" href="@Model.FirstUrl" aria-label="First page" title="First">&#171;</a>
            }
            @if (string.IsNullOrEmpty(Model.PrevUrl))
            {
                <span class="sh-pager-btn disabled" aria-disabled="true" aria-label="Previous page" title="Previous">&#8249;</span>
            }
            else
            {
                <a class="sh-pager-btn" href="@Model.PrevUrl" aria-label="Previous page" title="Previous">&#8249;</a>
            }
            @if (string.IsNullOrEmpty(Model.NextUrl))
            {
                <span class="sh-pager-btn disabled" aria-disabled="true" aria-label="Next page" title="Next">&#8250;</span>
            }
            else
            {
                <a class="sh-pager-btn" href="@Model.NextUrl" aria-label="Next page" title="Next">&#8250;</a>
            }
            @if (string.IsNullOrEmpty(Model.LastUrl))
            {
                <span class="sh-pager-btn disabled" aria-disabled="true" aria-label="Last page" title="Last">&#187;</span>
            }
            else
            {
                <a class="sh-pager-btn" href="@Model.LastUrl" aria-label="Last page" title="Last">&#187;</a>
            }
        </div>
    </div>
</nav>
